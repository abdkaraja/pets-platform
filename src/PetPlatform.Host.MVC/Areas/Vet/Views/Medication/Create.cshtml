@model PetPlatform.Application.DTOs.CreateMedicationDto

<div class="max-w-2xl">
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-800">Add Medication Record — @ViewData["PetName"]</h2>
        </div>
        <form asp-area="Vet" asp-controller="Medication" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PetId" />
            <div class="px-6 py-4 space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

                <div>
                    <label asp-for="MedicationName" class="block text-sm font-medium text-gray-700">Medication Name *</label>
                    <input asp-for="MedicationName" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="MedicationName" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Dosage" class="block text-sm font-medium text-gray-700">Dosage *</label>
                    <input asp-for="Dosage" placeholder="e.g. 500mg" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="Dosage" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Frequency" class="block text-sm font-medium text-gray-700">Frequency *</label>
                    <input asp-for="Frequency" placeholder="e.g. Twice daily" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="Frequency" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="StartDate" class="block text-sm font-medium text-gray-700">Start Date *</label>
                    <input asp-for="StartDate" type="date" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="StartDate" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="EndDate" class="block text-sm font-medium text-gray-700">End Date</label>
                    <input asp-for="EndDate" type="date" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="EndDate" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="PrescribingReason" class="block text-sm font-medium text-gray-700">Prescribing Reason / Diagnosis</label>
                    <input asp-for="PrescribingReason" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="PrescribingReason" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Instructions" class="block text-sm font-medium text-gray-700">Instructions</label>
                    <textarea asp-for="Instructions" rows="3" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm"></textarea>
                    <span asp-validation-for="Instructions" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="SideEffectsNoted" class="block text-sm font-medium text-gray-700">Side Effects Noted</label>
                    <textarea asp-for="SideEffectsNoted" rows="3" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm"></textarea>
                    <span asp-validation-for="SideEffectsNoted" class="text-red-600 text-xs"></span>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-gray-200 space-x-2">
                <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm">
                    Save Medication Record
                </button>
                <a asp-area="Vet" asp-controller="Pets" asp-action="Details" asp-route-id="@Model.PetId"
                   class="inline-block bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400 text-sm">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
