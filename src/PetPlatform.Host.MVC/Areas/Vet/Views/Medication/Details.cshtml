@model PetPlatform.Application.DTOs.MedicationRecordDto

<div class="max-w-2xl">
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-800">Medication Record</h2>
        </div>
        <div class="px-6 py-4 space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Pet</label>
                <p class="mt-1 text-sm text-gray-900">@Model.PetName</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Medication Name</label>
                <p class="mt-1 text-sm text-gray-900">@Model.MedicationName</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Dosage</label>
                <p class="mt-1 text-sm text-gray-900">@Model.Dosage</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Frequency</label>
                <p class="mt-1 text-sm text-gray-900">@Model.Frequency</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Start Date</label>
                <p class="mt-1 text-sm text-gray-900">@Model.StartDate.ToString("MMM dd, yyyy")</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">End Date</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.EndDate?.ToString("MMM dd, yyyy") ?? "Ongoing")</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Prescribing Reason</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.PrescribingReason ?? "N/A")</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Instructions</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.Instructions ?? "N/A")</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Side Effects Noted</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.SideEffectsNoted ?? "N/A")</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Recorded By</label>
                <p class="mt-1 text-sm text-gray-900">@Model.VetUserName</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Created</label>
                <p class="mt-1 text-sm text-gray-900">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
            </div>
        </div>
        <div class="px-6 py-4 border-t border-gray-200">
            <a asp-area="Vet" asp-controller="Pets" asp-action="Details" asp-route-id="@Model.PetId"
               class="text-blue-600 hover:text-blue-900 text-sm">&larr; Back to Pet</a>
        </div>
    </div>
</div>
