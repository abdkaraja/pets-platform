@model PetPlatform.Application.DTOs.CreateVaccinationDto

<div class="max-w-2xl">
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-800">Add Vaccination Record — @ViewData["PetName"]</h2>
        </div>
        <form asp-area="Vet" asp-controller="Vaccination" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PetId" />
            <div class="px-6 py-4 space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

                <div>
                    <label asp-for="VaccineName" class="block text-sm font-medium text-gray-700">Vaccine Name *</label>
                    <input asp-for="VaccineName" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="VaccineName" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="DateAdministered" class="block text-sm font-medium text-gray-700">Date Administered *</label>
                    <input asp-for="DateAdministered" type="date" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="DateAdministered" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="BatchLotNumber" class="block text-sm font-medium text-gray-700">Batch/Lot Number</label>
                    <input asp-for="BatchLotNumber" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="BatchLotNumber" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="NextDueDate" class="block text-sm font-medium text-gray-700">Next Due Date</label>
                    <input asp-for="NextDueDate" type="date" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="NextDueDate" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Notes" class="block text-sm font-medium text-gray-700">Notes / Reactions</label>
                    <textarea asp-for="Notes" rows="3" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm"></textarea>
                    <span asp-validation-for="Notes" class="text-red-600 text-xs"></span>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-gray-200 space-x-2">
                <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 text-sm">
                    Save Vaccination Record
                </button>
                <a asp-area="Vet" asp-controller="Pets" asp-action="Details" asp-route-id="@Model.PetId"
                   class="inline-block bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400 text-sm">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
