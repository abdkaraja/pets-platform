@model PetPlatform.Application.DTOs.VetAssignmentDto

<div class="max-w-2xl space-y-6">
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
            <p class="text-sm text-red-700">@TempData["Error"]</p>
        </div>
    }

    <!-- Pet Info Card -->
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-800">Assignment Details</h2>
        </div>
        <div class="px-6 py-4 space-y-3">
            <div>
                <label class="block text-sm font-medium text-gray-700">Pet Name</label>
                <p class="mt-1 text-sm text-gray-900">@Model.PetName</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Requested By</label>
                <p class="mt-1 text-sm text-gray-900">@Model.RequestedByUserId</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Request Date</label>
                <p class="mt-1 text-sm text-gray-900">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Status</label>
                <p class="mt-1 text-sm text-gray-900">@Model.Status</p>
            </div>
        </div>
    </div>

    <!-- Accept/Reject Actions -->
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-md font-semibold text-gray-800">Actions</h3>
        </div>
        <div class="px-6 py-4 space-y-4">
            @if (Model.Status == PetPlatform.Domain.Enums.VetAssignmentStatus.Pending)
            {
                <div class="flex space-x-3">
                    <form asp-area="Vet" asp-controller="Assignment" asp-action="Accept" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 text-sm">
                            Accept
                        </button>
                    </form>
                </div>
                <form asp-area="Vet" asp-controller="Assignment" asp-action="Reject" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Rejection Reason (optional)</label>
                        <textarea name="reason" rows="2" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm"></textarea>
                    </div>
                    <div class="mt-2">
                        <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 text-sm"
                                onclick="return confirm('Are you sure you want to reject this request?')">
                            Reject
                        </button>
                    </div>
                </form>
            }
            else
            {
                <p class="text-sm text-gray-500">This request has already been @(Model.Status.ToString().ToLower()).</p>
            }
        </div>
    </div>

    <div>
        <a asp-area="Vet" asp-controller="Assignment" asp-action="Pending"
           class="text-blue-600 hover:text-blue-900 text-sm">&larr; Back to Pending Requests</a>
    </div>
</div>
