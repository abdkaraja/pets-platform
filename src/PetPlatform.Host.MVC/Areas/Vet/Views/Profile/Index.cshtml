@model PetPlatform.Application.DTOs.VetProfileDto

<div class="max-w-2xl">
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-800">Vet Profile</h2>
        </div>
        <div class="px-6 py-4 space-y-4">
            @if (!Model.IsApproved)
            {
                <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4">
                    <p class="text-sm text-yellow-700">Your profile is pending admin approval.</p>
                </div>
            }

            <div>
                <label class="block text-sm font-medium text-gray-700">Full Name</label>
                <p class="mt-1 text-sm text-gray-900">@Model.FullName</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">Clinic</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.Clinic ?? "Not specified")</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">Specialty</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.Specialty ?? "Not specified")</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">Bio</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.Bio ?? "Not specified")</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">Services Offered</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.ServicesOffered ?? "Not specified")</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">Available</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.IsAvailable ? "Yes" : "No")</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">Approved</label>
                <p class="mt-1 text-sm text-gray-900">@(Model.IsApproved ? "Yes" : "Pending")</p>
            </div>
        </div>
        <div class="px-6 py-4 border-t border-gray-200">
            <a asp-area="Vet" asp-controller="Profile" asp-action="Edit"
               class="inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm">
                Edit Profile
            </a>
        </div>
    </div>
</div>
