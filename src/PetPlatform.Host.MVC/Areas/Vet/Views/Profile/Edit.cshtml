@model PetPlatform.Application.DTOs.UpdateVetProfileDto

<div class="max-w-2xl">
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-800">Edit Profile</h2>
        </div>
        <form asp-area="Vet" asp-controller="Profile" asp-action="Edit" asp-route-id="@ViewBag.ProfileId" method="post">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4 space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

                <div>
                    <label asp-for="FullName" class="block text-sm font-medium text-gray-700">Full Name *</label>
                    <input asp-for="FullName" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="FullName" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Clinic" class="block text-sm font-medium text-gray-700">Clinic</label>
                    <input asp-for="Clinic" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="Clinic" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Specialty" class="block text-sm font-medium text-gray-700">Specialty</label>
                    <input asp-for="Specialty" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <span asp-validation-for="Specialty" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Bio" class="block text-sm font-medium text-gray-700">Bio</label>
                    <textarea asp-for="Bio" rows="3" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm"></textarea>
                    <span asp-validation-for="Bio" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="ServicesOffered" class="block text-sm font-medium text-gray-700">Services Offered</label>
                    <input asp-for="ServicesOffered" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm" />
                    <p class="mt-1 text-xs text-gray-500">Comma-separated list of services</p>
                    <span asp-validation-for="ServicesOffered" class="text-red-600 text-xs"></span>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-gray-200 space-x-2">
                <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm">
                    Save Profile
                </button>
                <a asp-area="Vet" asp-controller="Profile" asp-action="Index"
                   class="inline-block bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400 text-sm">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
