@model IEnumerable<PetPlatform.Application.DTOs.AdoptionApplicationDto>
@using PetPlatform.Domain.Enums
@{
    ViewData["Title"] = "Applications";
    var listingId = (int)ViewBag.ListingId;
}

<div class="max-w-4xl mx-auto">
    <a asp-action="Listings" class="text-blue-600 hover:text-blue-800 text-sm mb-4 inline-block">&larr; Back to listings</a>

    <h1 class="text-2xl font-bold mb-6">Applications</h1>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="bg-white rounded-lg shadow p-12 text-center">
            <h2 class="text-2xl font-bold mb-2">No applications received yet</h2>
            <p class="text-gray-600">Applications will appear here when users apply for this listing.</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="text-left px-4 py-3 font-bold text-gray-700">Applicant</th>
                        <th class="text-left px-4 py-3 font-bold text-gray-700">Applied</th>
                        <th class="text-left px-4 py-3 font-bold text-gray-700">Status</th>
                        <th class="text-left px-4 py-3 font-bold text-gray-700">Message</th>
                        <th class="text-right px-4 py-3 font-bold text-gray-700">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var app in Model)
                    {
                        var badgeClass = app.Status switch
                        {
                            ApplicationStatus.Submitted => "bg-blue-100 text-blue-800",
                            ApplicationStatus.UnderReview => "bg-yellow-100 text-yellow-800",
                            ApplicationStatus.Approved => "bg-green-100 text-green-800",
                            ApplicationStatus.Rejected => "bg-red-100 text-red-800",
                            ApplicationStatus.Withdrawn => "bg-gray-100 text-gray-800",
                            _ => "bg-gray-100 text-gray-800"
                        };
                        var canReview = app.Status == ApplicationStatus.Submitted || app.Status == ApplicationStatus.UnderReview;
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-3 font-bold text-xs">@app.ApplicantUserId.Substring(0, Math.Min(8, app.ApplicantUserId.Length))...</td>
                            <td class="px-4 py-3 text-gray-600">@app.CreatedAt.ToString("MMM d")</td>
                            <td class="px-4 py-3">
                                <span class="text-xs px-2 py-1 rounded-full @badgeClass">@app.Status</span>
                            </td>
                            <td class="px-4 py-3 text-gray-600 max-w-xs truncate">
                                @(app.Message ?? "—")
                            </td>
                            <td class="px-4 py-3 text-right">
                                @if (canReview)
                                {
                                    <a asp-action="ReviewApplication" asp-route-applicationId="@app.Id" asp-route-listingId="@listingId"
                                       class="text-blue-600 hover:text-blue-800 text-xs font-bold">Review</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
