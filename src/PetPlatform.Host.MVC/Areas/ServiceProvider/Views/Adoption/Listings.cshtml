@model IEnumerable<PetPlatform.Application.DTOs.AdoptionListingDto>
@using PetPlatform.Domain.Enums
@{
    ViewData["Title"] = "My Adoption Listings";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">My Adoption Listings</h1>
    <a asp-action="CreateListing"
       class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-blue-700 transition-colors">
        Create New Listing
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
        @TempData["Error"]
    </div>
}

@if (!Model.Any())
{
    <div class="bg-white rounded-lg shadow p-12 text-center">
        <h2 class="text-2xl font-bold mb-2">No listings yet</h2>
        <p class="text-gray-600 mb-4">Create your first adoption listing.</p>
        <a asp-action="CreateListing"
           class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
            Create Listing
        </a>
    </div>
}
else
{
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="text-left px-4 py-3 font-bold text-gray-700">Pet</th>
                    <th class="text-left px-4 py-3 font-bold text-gray-700">Title</th>
                    <th class="text-left px-4 py-3 font-bold text-gray-700">Location</th>
                    <th class="text-left px-4 py-3 font-bold text-gray-700">Status</th>
                    <th class="text-center px-4 py-3 font-bold text-gray-700">Apps</th>
                    <th class="text-left px-4 py-3 font-bold text-gray-700">Created</th>
                    <th class="text-right px-4 py-3 font-bold text-gray-700">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var listing in Model)
                {
                    var badgeClass = listing.Status switch
                    {
                        ListingStatus.Active => "bg-green-100 text-green-800",
                        ListingStatus.Adopted => "bg-blue-100 text-blue-800",
                        ListingStatus.Closed => "bg-gray-100 text-gray-800",
                        ListingStatus.Pending => "bg-yellow-100 text-yellow-800",
                        _ => "bg-gray-100 text-gray-800"
                    };
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2">
                                @if (!string.IsNullOrEmpty(listing.PetPhotoPath))
                                {
                                    <img src="@listing.PetPhotoPath" alt="@listing.PetName" class="w-8 h-8 rounded object-cover" />
                                }
                                <span class="font-bold">@listing.PetName</span>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-gray-600">@listing.Title</td>
                        <td class="px-4 py-3 text-gray-600">@listing.Location</td>
                        <td class="px-4 py-3">
                            <span class="text-xs px-2 py-1 rounded-full @badgeClass">@listing.Status</span>
                        </td>
                        <td class="px-4 py-3 text-center text-gray-600">@listing.ApplicationCount</td>
                        <td class="px-4 py-3 text-gray-600">@listing.CreatedAt.ToString("MMM d")</td>
                        <td class="px-4 py-3 text-right space-x-2">
                            <a asp-action="EditListing" asp-route-id="@listing.Id"
                               class="text-blue-600 hover:text-blue-800 text-xs font-bold">Edit</a>
                            <a asp-action="Applications" asp-route-listingId="@listing.Id"
                               class="text-blue-600 hover:text-blue-800 text-xs font-bold">Applications</a>
                            @if (listing.Status == ListingStatus.Active)
                            {
                                <form asp-action="CloseListing" asp-route-id="@listing.Id" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-red-600 hover:text-red-800 text-xs font-bold"
                                            onclick="return confirm('Are you sure you want to close this listing?')">
                                        Close
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
