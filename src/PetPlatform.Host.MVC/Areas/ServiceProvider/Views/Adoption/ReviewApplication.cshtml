@model PetPlatform.Application.DTOs.ReviewApplicationDto
@using PetPlatform.Application.DTOs
@using PetPlatform.Domain.Enums
@{
    ViewData["Title"] = "Review Application";
    var app = (AdoptionApplicationDto)ViewBag.Application;
    var listingId = app.ListingId;
}

<div class="max-w-2xl mx-auto">
    <a asp-action="Applications" asp-route-listingId="@listingId" class="text-blue-600 hover:text-blue-800 text-sm mb-4 inline-block">&larr; Back to applications</a>

    @* Application Context *@
    <div class="bg-white rounded-lg shadow p-6 mb-6">
        <div class="flex items-center gap-3 mb-4">
            <h1 class="text-xl font-bold">Review Application</h1>
            <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-800">@app.Status</span>
        </div>

        <div class="space-y-3 text-sm text-gray-600">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <span class="font-bold">Applicant:</span>
                    <span class="text-xs">@app.ApplicantUserId.Substring(0, Math.Min(12, app.ApplicantUserId.Length))...</span>
                </div>
                <div>
                    <span class="font-bold">Applied:</span> @app.CreatedAt.ToString("MMM d, yyyy")
                </div>
            </div>
            <div>
                <span class="font-bold">Listing:</span> @app.ListingTitle
            </div>
            <div>
                <span class="font-bold">Pet:</span> @app.PetName
            </div>

            @if (!string.IsNullOrEmpty(app.Message))
            {
                <div class="mt-2">
                    <span class="font-bold">Message:</span>
                    <p class="bg-gray-50 rounded-lg p-3 mt-1 whitespace-pre-line">@app.Message</p>
                </div>
            }
        </div>
    </div>

    @* Review Form *@
    <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-sm font-bold text-gray-700 mb-4">Decision</h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
                <div asp-validation-summary="All" class="text-sm"></div>
            </div>
        }

        <form asp-action="ReviewApplication" asp-route-applicationId="@app.Id" asp-route-listingId="@listingId" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <div class="flex gap-4">
                    <label class="flex items-center gap-2 text-sm cursor-pointer">
                        <input type="radio" asp-for="Status" value="@ApplicationStatus.Approved"
                               class="accent-green-600" onchange="updateConfirmText(this)" />
                        <span class="text-green-700 font-bold">Approve</span>
                    </label>
                    <label class="flex items-center gap-2 text-sm cursor-pointer">
                        <input type="radio" asp-for="Status" value="@ApplicationStatus.Rejected"
                               class="accent-red-600" onchange="updateConfirmText(this)" />
                        <span class="text-red-700 font-bold">Reject</span>
                    </label>
                </div>
                <span asp-validation-for="Status" class="text-red-500 text-xs"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ReviewNotes" class="block text-sm font-bold text-gray-700 mb-1">Review Notes</label>
                <textarea asp-for="ReviewNotes" rows="3" maxlength="500"
                          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"
                          placeholder="Add notes for this decision (optional)..."></textarea>
                <span asp-validation-for="ReviewNotes" class="text-red-500 text-xs"></span>
            </div>

            <div class="flex gap-3">
                <button type="submit" id="submitBtn"
                        class="flex-1 bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
                    Submit Decision
                </button>
                <a asp-action="Applications" asp-route-listingId="@listingId"
                   class="px-6 py-3 rounded-lg border border-gray-300 text-gray-700 font-bold hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updateConfirmText(radio) {
            var btn = document.getElementById('submitBtn');
            btn.textContent = radio.value === '@ApplicationStatus.Approved' ? 'Approve Application' : 'Reject Application';
        }
        document.querySelector('form').addEventListener('submit', function(e) {
            var status = document.querySelector('input[name="Status"]:checked');
            if (!status) { e.preventDefault(); return; }
            var action = status.value === '@ApplicationStatus.Approved' ? 'approve' : 'reject';
            if (!confirm('Are you sure you want to ' + action + ' this application?')) {
                e.preventDefault();
            }
        });
    </script>
}
