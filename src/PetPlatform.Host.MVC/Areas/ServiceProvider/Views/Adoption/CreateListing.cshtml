@model PetPlatform.Application.DTOs.CreateListingDto
@{
    ViewData["Title"] = "Create Adoption Listing";
}

<div class="max-w-2xl mx-auto">
    <a asp-action="Listings" class="text-blue-600 hover:text-blue-800 text-sm mb-4 inline-block">&larr; Back to listings</a>

    <div class="bg-white rounded-lg shadow p-6">
        <h1 class="text-xl font-bold mb-4">Create Adoption Listing</h1>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
                <div asp-validation-summary="All" class="text-sm"></div>
            </div>
        }

        <form asp-action="CreateListing" method="post">
            @Html.AntiForgeryToken()

            <div class="space-y-4">
                <div>
                    <label asp-for="PetId" class="block text-sm font-bold text-gray-700 mb-1">Pet ID</label>
                    <input asp-for="PetId" type="number" min="1"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                    <span asp-validation-for="PetId" class="text-red-500 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Title" class="block text-sm font-bold text-gray-700 mb-1">Title</label>
                    <input asp-for="Title" type="text" maxlength="200"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"
                           placeholder="e.g. Friendly cat looking for a loving home" />
                    <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-1">Description</label>
                    <textarea asp-for="Description" rows="4" maxlength="2000"
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"
                              placeholder="Tell potential adopters about this pet..."></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Location" class="block text-sm font-bold text-gray-700 mb-1">Location</label>
                    <input asp-for="Location" type="text" maxlength="200"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"
                           placeholder="e.g. San Francisco, CA" />
                    <span asp-validation-for="Location" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <div class="flex gap-3 pt-6">
                <button type="submit" class="flex-1 bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
                    Create Listing
                </button>
                <a asp-action="Listings"
                   class="px-6 py-3 rounded-lg border border-gray-300 text-gray-700 font-bold hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
