@model List<PetPlatform.Host.MVC.Areas.Admin.Controllers.UserListItemViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-800">All Users</h2>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
            <thead class="bg-gray-50 text-gray-600">
                <tr>
                    <th class="px-6 py-3">Email</th>
                    <th class="px-6 py-3">Roles</th>
                    <th class="px-6 py-3">Status</th>
                    <th class="px-6 py-3">Created</th>
                    <th class="px-6 py-3">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 font-medium text-gray-900">@user.Email</td>
                        <td class="px-6 py-4 text-gray-600">@(string.IsNullOrEmpty(user.Roles) ? "—" : user.Roles)</td>
                        <td class="px-6 py-4">
                            @if (user.IsLockedOut)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                    Locked
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                    Active
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 text-gray-500">@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                                <a asp-action="Details" asp-route-id="@user.Id"
                                   class="text-blue-600 hover:underline">Details</a>

                                @if (user.IsLockedOut)
                                {
                                    <form asp-action="Activate" asp-route-id="@user.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="text-green-600 hover:underline">Activate</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Deactivate" asp-route-id="@user.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="text-red-600 hover:underline"
                                                onclick="return confirm('Are you sure you want to deactivate this user?')">
                                            Deactivate
                                        </button>
                                    </form>
                                }

                                <a asp-action="AssignRole" asp-route-id="@user.Id"
                                   class="text-purple-600 hover:underline">Assign Role</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Count == 0)
    {
        <div class="px-6 py-12 text-center text-gray-500">
            No users found.
        </div>
    }

    <!-- Pagination -->
    @if ((int)ViewBag.TotalPages > 1)
    {
        <div class="px-6 py-4 border-t border-gray-200 flex items-center justify-between">
            <span class="text-sm text-gray-500">
                Page @ViewBag.CurrentPage of @ViewBag.TotalPages
            </span>
            <div class="flex gap-2">
                @if ((int)ViewBag.CurrentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@((int)ViewBag.CurrentPage - 1)"
                       class="px-3 py-1 border rounded text-sm hover:bg-gray-50">Previous</a>
                }
                @if ((int)ViewBag.CurrentPage < (int)ViewBag.TotalPages)
                {
                    <a asp-action="Index" asp-route-page="@((int)ViewBag.CurrentPage + 1)"
                       class="px-3 py-1 border rounded text-sm hover:bg-gray-50">Next</a>
                }
            </div>
        </div>
    }
</div>
