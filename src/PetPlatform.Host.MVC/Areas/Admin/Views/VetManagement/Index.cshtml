@model PetPlatform.Application.DTOs.PagedResultDto<PetPlatform.Application.DTOs.VetProfileDto>
@{
    ViewData["Title"] = "Vet Management";
    var isApproved = ViewBag.IsApproved as bool?;
}

<div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">Vet Management</h1>
        <a asp-action="PendingApprovals" class="bg-yellow-500 hover:bg-yellow-600 text-white text-sm font-medium py-2 px-4 rounded">
            Pending Approvals
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
            @TempData["Error"]
        </div>
    }

    <!-- Filter Tabs -->
    <div class="flex gap-2 mb-4">
        <a asp-action="Index"
           class="px-4 py-2 rounded-full text-sm font-medium @(isApproved == null ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300")">
            All
        </a>
        <a asp-action="Index" asp-route-isApproved="true"
           class="px-4 py-2 rounded-full text-sm font-medium @(isApproved == true ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300")">
            Approved
        </a>
        <a asp-action="Index" asp-route-isApproved="false"
           class="px-4 py-2 rounded-full text-sm font-medium @(isApproved == false ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300")">
            Pending
        </a>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="bg-white rounded-lg shadow p-8 text-center">
            <p class="text-gray-500 text-lg">No vet profiles found</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b">
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Name</th>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Clinic</th>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Specialty</th>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Status</th>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Available</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vet in Model.Items)
                    {
                        <tr class="border-t hover:bg-gray-50">
                            <td class="px-4 py-3 font-medium text-gray-800">@vet.FullName</td>
                            <td class="px-4 py-3 text-gray-600">@(vet.Clinic ?? "—")</td>
                            <td class="px-4 py-3 text-gray-600">@(vet.Specialty ?? "—")</td>
                            <td class="px-4 py-3">
                                @if (vet.IsApproved)
                                {
                                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Approved</span>
                                }
                                else
                                {
                                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pending</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                @if (vet.IsAvailable)
                                {
                                    <span class="text-green-600">Yes</span>
                                }
                                else
                                {
                                    <span class="text-gray-400">No</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex gap-2 justify-end">
                                    <a asp-action="Details" asp-route-id="@vet.Id"
                                       class="text-blue-600 hover:text-blue-800 text-sm">View</a>
                                    @if (!vet.IsApproved)
                                    {
                                        <form asp-action="Approve" asp-route-id="@vet.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-green-600 hover:text-green-800 text-sm">Approve</button>
                                        </form>
                                        <form asp-action="Reject" asp-route-id="@vet.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-red-600 hover:text-red-800 text-sm">Reject</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex justify-center gap-2 mt-6">
                @if (Model.HasPreviousPage)
                {
                    <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-isApproved="@isApproved"
                       class="px-3 py-2 border border-gray-300 rounded text-sm hover:bg-gray-50">
                        &laquo; Previous
                    </a>
                }
                <span class="px-3 py-2 text-sm text-gray-600">Page @Model.Page of @Model.TotalPages</span>
                @if (Model.HasNextPage)
                {
                    <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-isApproved="@isApproved"
                       class="px-3 py-2 border border-gray-300 rounded text-sm hover:bg-gray-50">
                        Next &raquo;
                    </a>
                }
            </div>
        }
    }
</div>
