@model PetPlatform.Application.DTOs.VetProfileDto
@{
    ViewData["Title"] = $"Vet: {Model.FullName}";
}

<div class="max-w-4xl mx-auto">
    <div class="mb-6">
        <a asp-action="Index" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Back to Vet Management</a>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between mb-4">
            <h1 class="text-2xl font-bold text-gray-800">@Model.FullName</h1>
            @if (Model.IsApproved)
            {
                <span class="inline-block px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">Approved</span>
            }
            else
            {
                <span class="inline-block px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">Pending Approval</span>
            }
        </div>

        <div class="space-y-3 mb-6">
            <div>
                <span class="font-semibold text-gray-600">User ID:</span>
                <span class="ml-2 text-sm text-gray-500">@Model.UserId</span>
            </div>
            <div>
                <span class="font-semibold text-gray-600">Clinic:</span>
                <span class="ml-2">@(Model.Clinic ?? "Not specified")</span>
            </div>
            <div>
                <span class="font-semibold text-gray-600">Specialty:</span>
                <span class="ml-2">@(Model.Specialty ?? "Not specified")</span>
            </div>
            <div>
                <span class="font-semibold text-gray-600">Bio:</span>
                <p class="ml-2 text-gray-700 mt-1">@(Model.Bio ?? "No bio provided")</p>
            </div>
            <div>
                <span class="font-semibold text-gray-600">Services Offered:</span>
                <span class="ml-2">@(Model.ServicesOffered ?? "Not specified")</span>
            </div>
            <div>
                <span class="font-semibold text-gray-600">Available:</span>
                <span class="ml-2">@(Model.IsAvailable ? "Yes" : "No")</span>
            </div>
            <div>
                <span class="font-semibold text-gray-600">Registered:</span>
                <span class="ml-2">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex gap-3 pt-4 border-t">
            @if (!Model.IsApproved)
            {
                <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded">
                        Approve
                    </button>
                </form>
                <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded">
                        Reject
                    </button>
                </form>
            }
            <a asp-action="MedicalRecords" class="text-blue-600 hover:text-blue-800 py-2 px-4">
                View Medical Records
            </a>
        </div>
    </div>
</div>
