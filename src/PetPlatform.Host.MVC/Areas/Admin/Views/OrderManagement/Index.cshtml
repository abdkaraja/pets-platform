@model IEnumerable<PetPlatform.Application.DTOs.AdminOrderDto>

@{
    ViewData["Title"] = "Orders";
}

<div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-800">Orders</h2>
    </div>

    <!-- Filters -->
    <div class="px-6 py-4 border-b border-gray-200 flex flex-wrap gap-4">
        <form method="get" asp-action="Index" class="flex flex-wrap gap-4">
            <select name="status" class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
                <option value="">All Statuses</option>
                <option value="Pending" selected="@(ViewBag.StatusFilter?.ToString() == "Pending")">Pending</option>
                <option value="Processing" selected="@(ViewBag.StatusFilter?.ToString() == "Processing")">Processing</option>
                <option value="Shipped" selected="@(ViewBag.StatusFilter?.ToString() == "Shipped")">Shipped</option>
                <option value="Delivered" selected="@(ViewBag.StatusFilter?.ToString() == "Delivered")">Delivered</option>
            </select>
            <input type="search" name="searchTerm" value="@ViewBag.SearchTerm"
                   placeholder="Search by order #, customer..."
                   class="border border-gray-300 rounded-lg px-3 py-2 text-sm" />
            <button type="submit" class="px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">
                Filter
            </button>
        </form>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-start">
            <thead class="bg-gray-50 text-sm font-bold text-gray-600">
                <tr>
                    <th class="px-6 py-3 text-start">Order #</th>
                    <th class="px-6 py-3 text-start">Customer</th>
                    <th class="px-6 py-3 text-start">Date</th>
                    <th class="px-6 py-3 text-start">Total</th>
                    <th class="px-6 py-3 text-start">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var order in Model)
                {
                    <tr class="hover:bg-gray-50 cursor-pointer" onclick="location.href='@Url.Action("Details", new { id = order.Id })'">
                        <td class="px-6 py-4 font-bold text-gray-900">#@order.Id</td>
                        <td class="px-6 py-4 text-gray-600">@order.CustomerEmail</td>
                        <td class="px-6 py-4 text-gray-500 text-sm">@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="px-6 py-4 font-bold text-gray-900" dir="ltr">@order.TotalAmount.ToString("C")</td>
                        <td class="px-6 py-4">
                            @switch (order.Status)
                            {
                                case PetPlatform.Domain.Enums.OrderStatus.Pending:
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pending</span>
                                    break;
                                case PetPlatform.Domain.Enums.OrderStatus.Processing:
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Processing</span>
                                    break;
                                case PetPlatform.Domain.Enums.OrderStatus.Shipped:
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Shipped</span>
                                    break;
                                case PetPlatform.Domain.Enums.OrderStatus.Delivered:
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Delivered</span>
                                    break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-lg shadow p-12 text-center">
            <h3 class="text-2xl font-bold text-gray-700 mb-2">No orders</h3>
            <p class="text-gray-500">Orders will appear here once customers start purchasing.</p>
        </div>
    }
</div>
