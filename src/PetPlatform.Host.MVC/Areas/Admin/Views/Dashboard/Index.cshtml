@model dynamic

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
        <div class="text-sm font-medium text-gray-500 mb-1">Total Users</div>
        <div class="text-3xl font-bold text-gray-900">@ViewBag.TotalUsers</div>
        <a asp-area="Admin" asp-controller="User" asp-action="Index"
           class="text-sm text-blue-600 hover:underline mt-2 inline-block">View all users</a>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
        <div class="text-sm font-medium text-gray-500 mb-1">Total Roles</div>
        <div class="text-3xl font-bold text-gray-900">@ViewBag.TotalRoles</div>
        <a asp-area="Admin" asp-controller="Role" asp-action="Index"
           class="text-sm text-blue-600 hover:underline mt-2 inline-block">View all roles</a>
    </div>
</div>

<div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Quick Actions</h2>
    <div class="flex flex-wrap gap-3">
        <a asp-area="Admin" asp-controller="User" asp-action="Index"
           class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
            Manage Users
        </a>
        <a asp-area="Admin" asp-controller="Role" asp-action="Index"
           class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 text-sm">
            Manage Roles
        </a>
    </div>
</div>
