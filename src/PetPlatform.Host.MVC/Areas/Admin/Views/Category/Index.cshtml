@model IEnumerable<PetPlatform.Application.DTOs.CategoryDto>

@{
    ViewData["Title"] = "Categories";
}

<div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-800">Categories</h2>
        <a asp-action="Edit" asp-route-id=""
           class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
            + Add Category
        </a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm text-start">
            <thead class="bg-gray-50 text-sm font-bold text-gray-600">
                <tr>
                    <th class="px-6 py-3 text-start">Name</th>
                    <th class="px-6 py-3 text-start">Parent</th>
                    <th class="px-6 py-3 text-start">Products</th>
                    <th class="px-6 py-3 text-start">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @await Html.PartialAsync("_CategoryTreeRows", Model, new ViewDataDictionary(ViewData) { ["Level"] = 0 })
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-lg shadow p-12 text-center">
            <h3 class="text-2xl font-bold text-gray-700 mb-2">No categories</h3>
            <p class="text-gray-500 mb-6">Add a category to organize your products.</p>
            <a asp-action="Edit" asp-route-id=""
               class="inline-block bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
                Add Category
            </a>
        </div>
    }
</div>
