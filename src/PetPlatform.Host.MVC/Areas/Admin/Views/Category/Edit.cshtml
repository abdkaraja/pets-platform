@model PetPlatform.Application.DTOs.CreateCategoryDto

@{
    var isNew = Context.Request.Query["id"].Count == 0 || Context.Request.Query["id"] == "";
    ViewData["Title"] = isNew ? "Create Category" : "Edit Category";
}

<div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-800">@(isNew ? "Create Category" : "Edit Category")</h2>
    </div>

    <form asp-action="Edit" asp-route-id="@(isNew ? "0" : Context.Request.RouteValues["id"] ?? "0")"
          method="post" class="p-6 space-y-6">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label asp-for="Name" class="block text-sm font-bold text-gray-700 mb-1">Name *</label>
                <input asp-for="Name" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                <span asp-validation-for="Name" class="text-red-600 text-sm mt-1"></span>
            </div>
            <div>
                <label asp-for="ParentId" class="block text-sm font-bold text-gray-700 mb-1">Parent Category</label>
                <select asp-for="ParentId" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                    <option value="">None (Top Level)</option>
                    @if (ViewBag.ParentCategories is IEnumerable<PetPlatform.Application.DTOs.CategoryDto> categories)
                    {
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id" selected="@(Model.ParentId == cat.Id)">@cat.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="ParentId" class="text-red-600 text-sm mt-1"></span>
            </div>
        </div>

        <div class="flex items-center gap-4">
            <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-bold">
                Save Category
            </button>
            <a asp-action="Index" class="px-6 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm">
                Back to Categories
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
