@model PetPlatform.Host.MVC.Areas.Admin.Controllers.RoleDetailViewModel

@{
    ViewData["Title"] = $"Role: {Model.Name}";
}

<div class="max-w-2xl">
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-800">Role Details</h2>
        </div>
        <div class="px-6 py-4 space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-500">Name</label>
                <div class="mt-1 text-gray-900 font-medium">@Model.Name</div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-500">Description</label>
                <div class="mt-1 text-gray-900">@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-500 mb-2">Permission Claims</label>
                @if (Model.PermissionClaims.Any())
                {
                    <div class="space-y-2">
                        @foreach (var claim in Model.PermissionClaims)
                        {
                            <div class="flex items-center justify-between bg-gray-50 rounded px-4 py-2">
                                <span class="font-mono text-sm text-gray-700">@claim.ClaimValue</span>
                                <form asp-action="RemoveClaim" asp-route-roleId="@Model.Id" asp-route-claimId="@claim.ClaimId" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="text-red-600 hover:underline text-sm"
                                            onclick="return confirm('Remove this permission?')">
                                        Remove
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500 text-sm">No permission claims assigned</p>
                }
            </div>

            <!-- Add Permission Claim -->
            <div class="pt-2">
                <a asp-action="AddClaim" asp-route-roleId="@Model.Id"
                   class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 text-sm">
                    Add Permission Claim
                </a>
            </div>
        </div>
        <div class="px-6 py-4 border-t border-gray-200">
            <a asp-action="Index"
               class="px-4 py-2 border rounded text-sm hover:bg-gray-50">
                Back to List
            </a>
        </div>
    </div>
</div>
