@model IEnumerable<PetPlatform.Application.DTOs.ProductVariantDto>

@{
    ViewData["Title"] = "Inventory Management";
}

<div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-800">Inventory Management</h2>
    </div>

    <!-- Filters -->
    <div class="px-6 py-4 border-b border-gray-200 flex flex-wrap gap-4">
        <form method="get" asp-action="Index" class="flex flex-wrap gap-4">
            <input type="search" name="searchTerm" value="@ViewBag.SearchTerm"
                   placeholder="Search by product name, SKU..."
                   class="border border-gray-300 rounded-lg px-3 py-2 text-sm" />
            <select name="stockFilter" class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
                <option value="">All Stock</option>
                <option value="InStock" selected="@(ViewBag.StockFilter == "InStock")">In Stock</option>
                <option value="LowStock" selected="@(ViewBag.StockFilter == "LowStock")">Low Stock</option>
                <option value="OutOfStock" selected="@(ViewBag.StockFilter == "OutOfStock")">Out of Stock</option>
            </select>
            <button type="submit" class="px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">
                Filter
            </button>
        </form>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-start">
            <thead class="bg-gray-50 text-sm font-bold text-gray-600">
                <tr>
                    <th class="px-6 py-3 text-start">Product</th>
                    <th class="px-6 py-3 text-start">Variant</th>
                    <th class="px-6 py-3 text-start">SKU</th>
                    <th class="px-6 py-3 text-start">Stock</th>
                    <th class="px-6 py-3 text-start">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var variant in Model)
                {
                    <tr class="hover:bg-gray-50" data-variant-id="@variant.Id">
                        <td class="px-6 py-4 font-medium text-gray-900">
                            Product #@variant.ProductId
                        </td>
                        <td class="px-6 py-4 text-gray-600">
                            @{
                                var parts = new List<string>();
                                if (!string.IsNullOrEmpty(variant.Size)) { parts.Add($"Size: {variant.Size}"); }
                                if (!string.IsNullOrEmpty(variant.Color)) { parts.Add($"Color: {variant.Color}"); }
                                if (variant.Weight.HasValue) { parts.Add($"Weight: {variant.Weight}kg"); }
                                @(parts.Any() ? string.Join(", ", parts) : "—")
                            }
                        </td>
                        <td class="px-6 py-4 text-gray-600">@(variant.Sku ?? "—")</td>
                        <td class="px-6 py-4">
                            <span class="stock-display cursor-pointer hover:bg-gray-100 px-2 py-1 rounded"
                                  data-variant-id="@variant.Id"
                                  data-stock="@variant.StockQuantity">
                                @variant.StockQuantity
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            @if (variant.StockQuantity == 0)
                            {
                                <span class="text-red-600 text-xs font-medium">Out of Stock</span>
                            }
                            else if (variant.StockQuantity <= 5)
                            {
                                <span class="text-yellow-600 text-xs font-medium">Low Stock ⚠</span>
                            }
                            else
                            {
                                <span class="text-green-600 text-xs font-medium">In Stock</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-lg shadow p-12 text-center">
            <h3 class="text-2xl font-bold text-gray-700 mb-2">No variants found</h3>
            <p class="text-gray-500">Products must have variants to track inventory.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).on('click', '.stock-display', function () {
            var $el = $(this);
            var variantId = $el.data('variant-id');
            var currentStock = $el.data('stock');
            var $input = $('<input type="number" min="0" class="w-20 border border-gray-300 rounded px-2 py-1 text-sm" />')
                .val(currentStock);

            $el.replaceWith($input);
            $input.focus().select();

            function revert() {
                $input.replaceWith(
                    $('<span class="stock-display cursor-pointer hover:bg-gray-100 px-2 py-1 rounded" />')
                        .attr('data-variant-id', variantId)
                        .attr('data-stock', currentStock)
                        .text(currentStock)
                );
            }

            $input.on('keydown', function (e) {
                if (e.key === 'Escape') {
                    revert();
                } else if (e.key === 'Enter') {
                    e.preventDefault();
                    var newQuantity = parseInt($input.val(), 10);

                    if (isNaN(newQuantity) || newQuantity < 0) {
                        alert('Stock quantity must be a non-negative number.');
                        revert();
                        return;
                    }

                    $.ajax({
                        url: '@Url.Action("UpdateStock", "Inventory", new { area = "Admin" })',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({ variantId: variantId, newQuantity: newQuantity }),
                        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                        success: function (response) {
                            if (response.success) {
                                var $row = $input.closest('tr');
                                var $stockCell = $input.closest('td');
                                var $statusCell = $row.find('td:last');

                                // Update stock display
                                $input.replaceWith(
                                    $('<span class="stock-display cursor-pointer hover:bg-gray-100 px-2 py-1 rounded" />')
                                        .attr('data-variant-id', variantId)
                                        .attr('data-stock', response.newStock)
                                        .text(response.newStock)
                                );

                                // Update status
                                var statusHtml = '';
                                if (response.status === 'OutOfStock') {
                                    statusHtml = '<span class="text-red-600 text-xs font-medium">Out of Stock</span>';
                                } else if (response.status === 'LowStock') {
                                    statusHtml = '<span class="text-yellow-600 text-xs font-medium">Low Stock ⚠</span>';
                                } else {
                                    statusHtml = '<span class="text-green-600 text-xs font-medium">In Stock</span>';
                                }
                                $statusCell.html(statusHtml);
                            } else {
                                alert(response.message || 'Failed to update stock.');
                                revert();
                            }
                        },
                        error: function () {
                            alert('An error occurred while updating stock.');
                            revert();
                        }
                    });
                }
            });

            $input.on('blur', function () {
                revert();
            });
        });
    </script>
}
