@model PetPlatform.Application.DTOs.PagedResultDto<PetPlatform.Application.DTOs.ProductDto>

@{
    ViewData["Title"] = "Products";
}

<div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-800">Products</h2>
        <a asp-action="Create"
           class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
            + Add Product
        </a>
    </div>

    <!-- Filters -->
    <div class="px-6 py-4 border-b border-gray-200 flex flex-wrap gap-4">
        <form method="get" asp-action="Index" class="flex flex-wrap gap-4">
            <input type="search" name="searchTerm" value="@ViewBag.SearchTerm"
                   placeholder="Search products..."
                   class="border border-gray-300 rounded-lg px-3 py-2 text-sm" />
            <select name="categoryId" class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
                <option value="">All Categories</option>
                @if (ViewBag.Categories is IEnumerable<PetPlatform.Application.DTOs.CategoryDto> categories)
                {
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id" selected="@(ViewBag.CategoryId != null && (int?)ViewBag.CategoryId == cat.Id)">
                            @cat.Name
                        </option>
                    }
                }
            </select>
            <button type="submit" class="px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">
                Filter
            </button>
        </form>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-start">
            <thead class="bg-gray-50 text-sm font-bold text-gray-600">
                <tr>
                    <th class="px-6 py-3 text-start">Name</th>
                    <th class="px-6 py-3 text-start">Category</th>
                    <th class="px-6 py-3 text-start">Brand</th>
                    <th class="px-6 py-3 text-start">Price</th>
                    <th class="px-6 py-3 text-start">Stock</th>
                    <th class="px-6 py-3 text-start">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var product in Model.Items)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 font-medium text-gray-900">
                            <a asp-action="Edit" asp-route-id="@product.Id" class="text-blue-600 hover:underline">
                                @product.Name
                            </a>
                        </td>
                        <td class="px-6 py-4 text-gray-600">@product.CategoryName</td>
                        <td class="px-6 py-4 text-gray-600">@product.BrandName</td>
                        <td class="px-6 py-4 text-gray-900" dir="ltr">@product.BasePrice.ToString("C")</td>
                        <td class="px-6 py-4">
                            @if (product.TotalStock == 0)
                            {
                                <span class="text-red-600">@product.TotalStock</span>
                            }
                            else if (product.TotalStock <= 5)
                            {
                                <span class="text-yellow-600">@product.TotalStock</span>
                            }
                            else
                            {
                                <span class="text-gray-900">@product.TotalStock</span>
                            }
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                                <a asp-action="Edit" asp-route-id="@product.Id"
                                   class="text-blue-600 hover:text-blue-800" aria-label="Edit @product.Name">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>
                                <form asp-action="Delete" asp-route-id="@product.Id" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="text-red-600 hover:text-red-800"
                                            onclick="return confirm('Are you sure you want to delete \'@product.Name\'? This cannot be undone.')"
                                            aria-label="Delete @product.Name">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="bg-white rounded-lg shadow p-12 text-center">
            <h3 class="text-2xl font-bold text-gray-700 mb-2">No products</h3>
            <p class="text-gray-500 mb-6">Create your first product to get started.</p>
            <a asp-action="Create"
               class="inline-block bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
                Add Product
            </a>
        </div>
    }

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="px-6 py-4 border-t border-gray-200 flex items-center justify-between">
            <span class="text-sm text-gray-500">
                Showing @(Model.Page == 1 ? 1 : (Model.Page - 1) * Model.PageSize + 1)-@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount)) of @Model.TotalCount products
            </span>
            <div class="flex gap-2">
                @if (Model.HasPreviousPage)
                {
                    <a asp-action="Index" asp-route-page="@(Model.Page - 1)"
                       class="px-3 py-1 border rounded text-sm hover:bg-gray-50">Previous</a>
                }
                @for (int i = 1; i <= Math.Min(Model.TotalPages, 5); i++)
                {
                    <a asp-action="Index" asp-route-page="@i"
                       class="px-3 py-1 border rounded text-sm @(i == Model.Page ? "bg-blue-600 text-white border-blue-600" : "hover:bg-gray-50")">
                        @i
                    </a>
                }
                @if (Model.HasNextPage)
                {
                    <a asp-action="Index" asp-route-page="@(Model.Page + 1)"
                       class="px-3 py-1 border rounded text-sm hover:bg-gray-50">Next</a>
                }
            </div>
        </div>
    }
</div>
