@model IEnumerable<PetPlatform.Application.DTOs.VetAssignmentDto>
@{
    ViewData["Title"] = "Vet Assignments";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var statusFilter = ViewBag.StatusFilter as PetPlatform.Domain.Enums.VetAssignmentStatus?;
}

<div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">Vet Assignments</h1>
        <a asp-action="Create"
           class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 px-4 rounded">
            Create Assignment
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
            @TempData["Error"]
        </div>
    }

    <!-- Filter Tabs -->
    <div class="flex gap-2 mb-4">
        <a asp-action="Index"
           class="px-4 py-2 rounded-full text-sm font-medium @(statusFilter == null ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300")">
            All
        </a>
        <a asp-action="Index" asp-route-status="@PetPlatform.Domain.Enums.VetAssignmentStatus.Pending"
           class="px-4 py-2 rounded-full text-sm font-medium @(statusFilter == PetPlatform.Domain.Enums.VetAssignmentStatus.Pending ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300")">
            Pending
        </a>
        <a asp-action="Index" asp-route-status="@PetPlatform.Domain.Enums.VetAssignmentStatus.Accepted"
           class="px-4 py-2 rounded-full text-sm font-medium @(statusFilter == PetPlatform.Domain.Enums.VetAssignmentStatus.Accepted ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300")">
            Accepted
        </a>
        <a asp-action="Index" asp-route-status="@PetPlatform.Domain.Enums.VetAssignmentStatus.Rejected"
           class="px-4 py-2 rounded-full text-sm font-medium @(statusFilter == PetPlatform.Domain.Enums.VetAssignmentStatus.Rejected ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-700 hover:bg-gray-300")">
            Rejected
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-lg shadow p-8 text-center">
            <p class="text-gray-500 text-lg">No assignments found</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b">
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Pet</th>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Vet</th>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Status</th>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Requested By</th>
                        <th class="px-4 py-3 text-left text-gray-600 font-medium">Date</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var assignment in Model)
                    {
                        string badgeClass = assignment.Status switch
                        {
                            PetPlatform.Domain.Enums.VetAssignmentStatus.Pending => "bg-yellow-100 text-yellow-800",
                            PetPlatform.Domain.Enums.VetAssignmentStatus.Accepted => "bg-green-100 text-green-800",
                            PetPlatform.Domain.Enums.VetAssignmentStatus.Rejected => "bg-red-100 text-red-800",
                            _ => "bg-gray-100 text-gray-800"
                        };

                        <tr class="border-t hover:bg-gray-50">
                            <td class="px-4 py-3 font-medium text-gray-800">@assignment.PetName</td>
                            <td class="px-4 py-3 text-gray-600">@assignment.VetFullName</td>
                            <td class="px-4 py-3">
                                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium @badgeClass">
                                    @assignment.Status
                                </span>
                            </td>
                            <td class="px-4 py-3 text-gray-500 text-xs">@assignment.RequestedByUserId</td>
                            <td class="px-4 py-3 text-gray-500">@assignment.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex gap-2 justify-end">
                                    <a asp-area="Customer" asp-controller="MyPets" asp-action="Details" asp-route-id="@assignment.PetId"
                                       class="text-blue-600 hover:text-blue-800 text-sm">View Pet</a>
                                    <a asp-area="Admin" asp-controller="VetManagement" asp-action="Details" asp-route-id="@assignment.VetProfileId"
                                       class="text-blue-600 hover:text-blue-800 text-sm">View Vet</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="flex justify-center gap-2 mt-6">
                @if (currentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-status="@statusFilter"
                       class="px-3 py-2 border border-gray-300 rounded text-sm hover:bg-gray-50">
                        &laquo; Previous
                    </a>
                }
                <span class="px-3 py-2 text-sm text-gray-600">Page @currentPage of @totalPages</span>
                @if (currentPage < totalPages)
                {
                    <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-status="@statusFilter"
                       class="px-3 py-2 border border-gray-300 rounded text-sm hover:bg-gray-50">
                        Next &raquo;
                    </a>
                }
            </div>
        }
    }
</div>
