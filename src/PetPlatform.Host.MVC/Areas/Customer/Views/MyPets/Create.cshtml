@model PetPlatform.Application.DTOs.CreatePetDto
@{
    ViewData["Title"] = "Add Pet";
}

<h1 class="text-2xl font-bold mb-6">Add Pet</h1>

<div class="bg-white rounded-lg shadow p-6 max-w-lg">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>

        <div class="mb-4">
            <label asp-for="Name" class="block font-semibold text-gray-600 mb-1">Name</label>
            <input asp-for="Name" class="w-full border border-gray-300 rounded px-3 py-2" />
            <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Species" class="block font-semibold text-gray-600 mb-1">Species</label>
            <select asp-for="Species" asp-items="Html.GetEnumSelectList<PetPlatform.Domain.Enums.PetSpecies>()" class="w-full border border-gray-300 rounded px-3 py-2">
                <option value="">-- Select Species --</option>
            </select>
            <span asp-validation-for="Species" class="text-red-500 text-sm"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Breed" class="block font-semibold text-gray-600 mb-1">Breed</label>
            <input asp-for="Breed" class="w-full border border-gray-300 rounded px-3 py-2" />
            <span asp-validation-for="Breed" class="text-red-500 text-sm"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Age" class="block font-semibold text-gray-600 mb-1">Age (years)</label>
            <input asp-for="Age" type="number" min="0" max="50" class="w-full border border-gray-300 rounded px-3 py-2" />
            <span asp-validation-for="Age" class="text-red-500 text-sm"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Weight" class="block font-semibold text-gray-600 mb-1">Weight (kg)</label>
            <input asp-for="Weight" type="number" step="0.1" min="0" max="500" class="w-full border border-gray-300 rounded px-3 py-2" />
            <span asp-validation-for="Weight" class="text-red-500 text-sm"></span>
        </div>

        <div class="mb-6">
            <label asp-for="Photo" class="block font-semibold text-gray-600 mb-1">Photo</label>
            <input asp-for="Photo" type="file" accept=".jpg,.jpeg,.png,.webp" class="w-full border border-gray-300 rounded px-3 py-2" />
            <span asp-validation-for="Photo" class="text-red-500 text-sm"></span>
            <p class="text-gray-400 text-sm mt-1">JPG, PNG, or WebP. Max 5MB.</p>
        </div>

        <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded">
            Create Pet
        </button>
        <a asp-action="Index" class="ml-4 text-gray-600 hover:text-gray-800">Cancel</a>
    </form>
</div>
