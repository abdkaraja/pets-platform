@model PetPlatform.Application.DTOs.PetDto
@{
    ViewData["Title"] = "Delete Pet";
}

<h1 class="text-2xl font-bold mb-6">Delete Pet</h1>

<div class="bg-white rounded-lg shadow p-6 max-w-lg">
    <div class="text-red-600 font-semibold mb-4">
        Are you sure you want to delete this pet?
    </div>

    <div class="space-y-3 mb-6">
        <div>
            <span class="font-semibold text-gray-600">Name:</span>
            <span class="ml-2">@Model.Name</span>
        </div>
        <div>
            <span class="font-semibold text-gray-600">Species:</span>
            <span class="ml-2">@Model.Species</span>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded">
            Confirm Delete
        </button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="ml-4 text-gray-600 hover:text-gray-800">
            Cancel
        </a>
    </form>
</div>
