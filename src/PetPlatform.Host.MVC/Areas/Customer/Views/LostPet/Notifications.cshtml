@model IEnumerable<PetPlatform.Application.DTOs.MatchNotificationDto>
@{
    ViewData["Title"] = "Match Notifications";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-3 mb-6">
        <h1 class="text-2xl font-bold">Match Notifications</h1>
        @if (unreadCount > 0)
        {
            <span class="inline-block px-2 py-1 text-xs font-bold rounded bg-blue-100 text-blue-800">
                @unreadCount new
            </span>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="bg-white rounded-lg shadow p-12 text-center">
            <h2 class="text-2xl font-bold mb-2">No notifications yet</h2>
            <p class="text-gray-600 mb-4">When a pet report matches yours, you'll see it here.</p>
            <div class="flex justify-center gap-4">
                <a asp-area="Customer" asp-controller="LostPet" asp-action="MyReports"
                   class="text-blue-600 hover:text-blue-800 font-bold">My Reports</a>
                <a asp-controller="LostPet" asp-action="Index"
                   class="text-blue-600 hover:text-blue-800 font-bold">Report a Pet</a>
            </div>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var notification in Model)
            {
                <div class="bg-white rounded-lg shadow p-4 @(notification.IsRead ? "border-l-4 border-gray-300" : "border-l-4 border-blue-500")">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <div class="flex items-center gap-2 mb-2">
                                @if (!notification.IsRead)
                                {
                                    <span class="inline-block w-2 h-2 rounded-full bg-blue-500"></span>
                                }
                                <span class="text-sm text-gray-500">@notification.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            <p class="text-gray-700 mb-2">@notification.Message</p>
                            @if (notification.MatchedReportSpecies != null)
                            {
                                <div class="text-sm text-gray-500">
                                    <span class="font-bold">Species:</span> @notification.MatchedReportSpecies
                                    @if (notification.MatchedReportLocation != null)
                                    {
                                        <span class="mx-2">|</span>
                                        <span class="font-bold">Location:</span> @notification.MatchedReportLocation
                                    }
                                </div>
                                @if (notification.MatchedReportDescription != null)
                                {
                                    <p class="text-sm text-gray-500 mt-1 line-clamp-2">@notification.MatchedReportDescription</p>
                                }
                            }
                        </div>
                        <div class="flex items-center gap-2 ml-4">
                            <a asp-controller="LostPet" asp-action="Details" asp-route-id="@notification.MatchedReportId"
                               class="text-blue-600 hover:text-blue-800 text-sm font-bold">View Report</a>
                            @if (!notification.IsRead)
                            {
                                <form asp-action="MarkNotificationRead" asp-route-notificationId="@notification.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-gray-500 hover:text-gray-700 text-sm">Dismiss</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
