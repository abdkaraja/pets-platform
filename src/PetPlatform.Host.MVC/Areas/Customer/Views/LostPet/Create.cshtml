@model PetPlatform.Application.DTOs.CreateLostPetReportDto
@using PetPlatform.Domain.Enums
@{
    ViewData["Title"] = "Report Lost/Found Pet";
}

<div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Report Lost/Found Pet</h1>

    <div class="bg-white rounded-lg shadow p-6">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4"></div>

            @* Report Type *@
            <div class="mb-4">
                <label class="block text-sm font-bold text-gray-700 mb-2">Report Type *</label>
                <div class="flex gap-4">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" asp-for="ReportType" value="Lost" class="accent-red-600" />
                        <span class="text-red-600 font-bold">Lost</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" asp-for="ReportType" value="Found" class="accent-green-600" />
                        <span class="text-green-600 font-bold">Found</span>
                    </label>
                </div>
                <span asp-validation-for="ReportType" class="text-red-600 text-sm"></span>
            </div>

            @* Species *@
            <div class="mb-4">
                <label asp-for="Species" class="block text-sm font-bold text-gray-700 mb-2">Species *</label>
                <select asp-for="Species" class="w-full border border-gray-300 rounded-lg px-3 py-2">
                    <option value="">Select Species</option>
                    @foreach (var s in Enum.GetValues<PetSpecies>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <span asp-validation-for="Species" class="text-red-600 text-sm"></span>
            </div>

            @* Breed *@
            <div class="mb-4">
                <label asp-for="Breed" class="block text-sm font-bold text-gray-700 mb-2">Breed</label>
                <input asp-for="Breed" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="e.g., Labrador, Siamese..." />
                <span asp-validation-for="Breed" class="text-red-600 text-sm"></span>
            </div>

            @* Color *@
            <div class="mb-4">
                <label asp-for="Color" class="block text-sm font-bold text-gray-700 mb-2">Color *</label>
                <input asp-for="Color" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="e.g., Brown and white..." />
                <span asp-validation-for="Color" class="text-red-600 text-sm"></span>
            </div>

            @* Location *@
            <div class="mb-4">
                <label asp-for="Location" class="block text-sm font-bold text-gray-700 mb-2">Location *</label>
                <input asp-for="Location" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="e.g., Downtown Cairo, Maadi, etc." />
                <span asp-validation-for="Location" class="text-red-600 text-sm"></span>
            </div>

            @* Date Reported *@
            <div class="mb-4">
                <label asp-for="DateReported" class="block text-sm font-bold text-gray-700 mb-2">Date *</label>
                <input asp-for="DateReported" type="date" class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                <span asp-validation-for="DateReported" class="text-red-600 text-sm"></span>
            </div>

            @* Description *@
            <div class="mb-4">
                <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-2">Description *</label>
                <textarea asp-for="Description" rows="4" class="w-full border border-gray-300 rounded-lg px-3 py-2" 
                          placeholder="Describe the pet, circumstances, distinguishing features..."></textarea>
                <span asp-validation-for="Description" class="text-red-600 text-sm"></span>
            </div>

            @* PetId *@
            <div class="mb-4">
                <label asp-for="PetId" class="block text-sm font-bold text-gray-700 mb-2">Link to Your Pet (Optional)</label>
                <input asp-for="PetId" type="number" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="Pet ID" />
                <span asp-validation-for="PetId" class="text-red-600 text-sm"></span>
            </div>

            @* Photo Upload *@
            <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-2">Photos (1-5 required)</label>
                <input type="file" name="photos" id="photoInput" multiple accept="image/*"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                <p class="text-xs text-gray-500 mt-1">Upload 1-5 photos of the pet (JPG, PNG, max 5MB each)</p>
                <div id="photoPreview" class="flex gap-2 mt-2 flex-wrap"></div>
                <p id="photoCount" class="text-sm text-gray-600 mt-1">0/5 photos selected</p>
            </div>

            @* Submit *@
            <div class="flex gap-4">
                <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
                    Submit Report
                </button>
                <a asp-controller="LostPet" asp-action="Index" class="text-gray-600 hover:text-gray-800 font-bold py-3">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const photoInput = document.getElementById('photoInput');
        const photoPreview = document.getElementById('photoPreview');
        const photoCount = document.getElementById('photoCount');
        const maxPhotos = 5;

        photoInput.addEventListener('change', function(e) {
            const files = Array.from(e.target.files);
            if (files.length > maxPhotos) {
                alert(`You can only upload up to ${maxPhotos} photos.`);
                photoInput.value = '';
                return;
            }
            photoPreview.innerHTML = '';
            files.forEach(file => {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.className = 'w-20 h-20 object-cover rounded';
                photoPreview.appendChild(img);
            });
            photoCount.textContent = `${files.length}/${maxPhotos} photos selected`;
        });
    </script>
}
