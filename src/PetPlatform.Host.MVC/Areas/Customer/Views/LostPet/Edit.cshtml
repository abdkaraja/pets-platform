@model PetPlatform.Application.DTOs.UpdateLostPetReportDto
@using PetPlatform.Domain.Enums
@{
    ViewData["Title"] = "Edit Report";
    var existingPhotos = (IEnumerable<PetPlatform.Application.DTOs.LostPetReportPhotoDto>?)ViewBag.ExistingPhotos;
}

<div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Edit Report</h1>

    <div class="bg-white rounded-lg shadow p-6">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4"></div>

            @* Color *@
            <div class="mb-4">
                <label asp-for="Color" class="block text-sm font-bold text-gray-700 mb-2">Color *</label>
                <input asp-for="Color" class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                <span asp-validation-for="Color" class="text-red-600 text-sm"></span>
            </div>

            @* Breed *@
            <div class="mb-4">
                <label asp-for="Breed" class="block text-sm font-bold text-gray-700 mb-2">Breed</label>
                <input asp-for="Breed" class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                <span asp-validation-for="Breed" class="text-red-600 text-sm"></span>
            </div>

            @* Location *@
            <div class="mb-4">
                <label asp-for="Location" class="block text-sm font-bold text-gray-700 mb-2">Location *</label>
                <input asp-for="Location" class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                <span asp-validation-for="Location" class="text-red-600 text-sm"></span>
            </div>

            @* Date Reported *@
            <div class="mb-4">
                <label asp-for="DateReported" class="block text-sm font-bold text-gray-700 mb-2">Date *</label>
                <input asp-for="DateReported" type="date" class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                <span asp-validation-for="DateReported" class="text-red-600 text-sm"></span>
            </div>

            @* Description *@
            <div class="mb-4">
                <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-2">Description *</label>
                <textarea asp-for="Description" rows="4" class="w-full border border-gray-300 rounded-lg px-3 py-2"></textarea>
                <span asp-validation-for="Description" class="text-red-600 text-sm"></span>
            </div>

            @* Existing Photos *@
            @if (existingPhotos != null && existingPhotos.Any())
            {
                <div class="mb-4">
                    <label class="block text-sm font-bold text-gray-700 mb-2">Current Photos</label>
                    <div class="flex gap-2 flex-wrap">
                        @foreach (var photo in existingPhotos)
                        {
                            <div class="relative">
                                <img src="@photo.PhotoPath" alt="Pet photo" class="w-20 h-20 object-cover rounded" />
                            </div>
                        }
                    </div>
                </div>
            }

            @* New Photos *@
            <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-2">Add More Photos</label>
                <input type="file" name="photos" id="photoInput" multiple accept="image/*"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                <p class="text-xs text-gray-500 mt-1">Add more photos (max 5 total)</p>
                <div id="photoPreview" class="flex gap-2 mt-2 flex-wrap"></div>
                <p id="photoCount" class="text-sm text-gray-600 mt-1">0 new photos selected</p>
            </div>

            @* Submit *@
            <div class="flex gap-4">
                <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
                    Save Changes
                </button>
                <a asp-action="ReportDetails" asp-route-id="@ViewContext.RouteData.Values["id"]" class="text-gray-600 hover:text-gray-800 font-bold py-3">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const photoInput = document.getElementById('photoInput');
        const photoPreview = document.getElementById('photoPreview');
        const photoCount = document.getElementById('photoCount');
        const maxPhotos = 5;

        photoInput.addEventListener('change', function(e) {
            const files = Array.from(e.target.files);
            if (files.length > maxPhotos) {
                alert(`You can only upload up to ${maxPhotos} photos.`);
                photoInput.value = '';
                return;
            }
            photoPreview.innerHTML = '';
            files.forEach(file => {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.className = 'w-20 h-20 object-cover rounded';
                photoPreview.appendChild(img);
            });
            photoCount.textContent = `${files.length} new photos selected`;
        });
    </script>
}
