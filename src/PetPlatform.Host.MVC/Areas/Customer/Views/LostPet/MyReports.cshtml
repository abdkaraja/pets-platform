@model IEnumerable<PetPlatform.Application.DTOs.LostPetReportDto>
@using PetPlatform.Domain.Enums
@{
    ViewData["Title"] = "My Lost Pet Reports";
}

<div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">My Lost Pet Reports</h1>
        <a asp-area="Customer" asp-controller="LostPet" asp-action="Create"
           class="bg-blue-600 text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-700 transition-colors">
            Report New Pet
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="bg-white rounded-lg shadow p-12 text-center">
            <h2 class="text-2xl font-bold mb-2">No reports yet</h2>
            <p class="text-gray-600 mb-4">You haven't reported any lost or found pets yet.</p>
            <a asp-area="Customer" asp-controller="LostPet" asp-action="Create"
               class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
                Report a Lost or Found Pet
            </a>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Type</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Species</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Color</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Location</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Date</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var report in Model)
                    {
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-block px-2 py-1 text-xs font-bold rounded @(report.ReportType == LostPetReportType.Lost ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800")">
                                    @report.ReportType
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">@report.Species</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">@report.Color</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">@report.Location</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">@report.DateReported.ToString("MMM dd, yyyy")</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-block px-2 py-1 text-xs font-bold rounded @(report.Status == LostPetReportStatus.Open ? "bg-blue-100 text-blue-800" : "bg-gray-100 text-gray-800")">
                                    @report.Status
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <div class="flex gap-2">
                                    <a asp-action="ReportDetails" asp-route-id="@report.Id" class="text-blue-600 hover:text-blue-800">View</a>
                                    @if (report.Status == LostPetReportStatus.Open)
                                    {
                                        <a asp-action="Edit" asp-route-id="@report.Id" class="text-blue-600 hover:text-blue-800">Edit</a>
                                        <form asp-action="Resolve" asp-route-id="@report.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-green-600 hover:text-green-800"
                                                    onclick="return confirm('Are you sure this pet has been found/recovered?')">
                                                Resolve
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
