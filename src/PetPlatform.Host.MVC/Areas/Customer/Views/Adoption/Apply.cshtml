@model PetPlatform.Application.DTOs.CreateApplicationDto
@using PetPlatform.Domain.Enums
@{
    ViewData["Title"] = "Apply for Adoption";
    var listing = (PetPlatform.Application.DTOs.AdoptionListingDto)ViewBag.Listing;
}

<div class="max-w-2xl mx-auto">
    <a asp-area="" asp-controller="Adoption" asp-action="Details" asp-route-id="@listing.Id"
       class="text-blue-600 hover:text-blue-800 text-sm mb-4 inline-block">&larr; Back to listing</a>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4">
            @TempData["Success"]
        </div>
    }

    @* Listing Summary *@
    <div class="bg-white rounded-lg shadow p-4 mb-6 flex gap-4">
        @if (!string.IsNullOrEmpty(listing.PetPhotoPath))
        {
            <img src="@listing.PetPhotoPath" alt="@listing.PetName" class="w-20 h-20 rounded object-cover" />
        }
        else
        {
            <div class="w-20 h-20 rounded bg-gray-200 flex items-center justify-center shrink-0">
                <span class="text-gray-400 text-xs">No Photo</span>
            </div>
        }
        <div>
            <h2 class="font-bold">@listing.PetName</h2>
            <p class="text-sm text-gray-600">@listing.PetSpecies @(!string.IsNullOrEmpty(listing.PetBreed) ? $"— {listing.PetBreed}" : "")</p>
            <p class="text-sm text-gray-600">@listing.Title &mdash; @listing.Location</p>
        </div>
    </div>

    @* Application Form *@
    <div class="bg-white rounded-lg shadow p-6">
        <h1 class="text-xl font-bold mb-4">Adoption Application</h1>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
                <div asp-validation-summary="All" class="text-sm"></div>
            </div>
        }

        <form asp-action="Apply" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ListingId" />

            @* Message *@
            <div class="mb-4">
                <label asp-for="Message" class="block text-sm font-bold text-gray-700 mb-1">
                    Tell the shelter why you'd be a great home for this pet
                </label>
                <textarea asp-for="Message" rows="4" maxlength="1000"
                          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"
                          placeholder="Share your story..."></textarea>
                <span asp-validation-for="Message" class="text-red-500 text-xs"></span>
            </div>

            @* Household Information *@
            <h2 class="text-sm font-bold text-gray-700 mb-2 mt-6">Household Information</h2>
            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label asp-for="HousingType" class="block text-sm font-bold text-gray-700 mb-1">Housing Type</label>
                    <select asp-for="HousingType" asp-items="Html.GetEnumSelectList<HousingType>()"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                        <option value="">Select...</option>
                    </select>
                    <span asp-validation-for="HousingType" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="NumberOfOccupants" class="block text-sm font-bold text-gray-700 mb-1">Number of Occupants</label>
                    <input asp-for="NumberOfOccupants" type="number" min="1"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
                    <span asp-validation-for="NumberOfOccupants" class="text-red-500 text-xs"></span>
                </div>
            </div>
            <div class="flex gap-6 mb-4">
                <label class="flex items-center gap-2 text-sm">
                    <input asp-for="HasYard" type="checkbox" class="accent-blue-600" />
                    I have a fenced yard
                </label>
                <label class="flex items-center gap-2 text-sm">
                    <input asp-for="HasChildren" type="checkbox" class="accent-blue-600" />
                    There are children in the household
                </label>
            </div>

            @* Pet Experience *@
            <h2 class="text-sm font-bold text-gray-700 mb-2 mt-6">Pet Experience</h2>
            <div class="space-y-4 mb-4">
                <div>
                    <label asp-for="PreviousPets" class="block text-sm font-bold text-gray-700 mb-1">Previous Pets</label>
                    <textarea asp-for="PreviousPets" rows="2" maxlength="1000"
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"
                              placeholder="Describe any pets you've previously owned..."></textarea>
                    <span asp-validation-for="PreviousPets" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="CurrentPets" class="block text-sm font-bold text-gray-700 mb-1">Current Pets</label>
                    <textarea asp-for="CurrentPets" rows="2" maxlength="1000"
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"
                              placeholder="Describe any current pets in your home..."></textarea>
                    <span asp-validation-for="CurrentPets" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="ExperienceLevel" class="block text-sm font-bold text-gray-700 mb-1">Experience Level</label>
                    <input asp-for="ExperienceLevel" type="text" maxlength="100"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"
                           placeholder="e.g. First-time owner, Experienced" />
                    <span asp-validation-for="ExperienceLevel" class="text-red-500 text-xs"></span>
                </div>
            </div>

            @* Actions *@
            <div class="flex gap-3 pt-4">
                <button type="submit" class="flex-1 bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
                    Submit Application
                </button>
                <a asp-area="" asp-controller="Adoption" asp-action="Details" asp-route-id="@listing.Id"
                   class="px-6 py-3 rounded-lg border border-gray-300 text-gray-700 font-bold hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
