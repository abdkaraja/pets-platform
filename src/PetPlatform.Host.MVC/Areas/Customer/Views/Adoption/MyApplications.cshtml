@model IEnumerable<PetPlatform.Application.DTOs.AdoptionApplicationDto>
@using PetPlatform.Domain.Enums
@{
    ViewData["Title"] = "My Applications";
}

<h1 class="text-2xl font-bold mb-6">My Applications</h1>

@if (TempData["Success"] != null)
{
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
        @TempData["Error"]
    </div>
}

@if (!Model.Any())
{
    <div class="bg-white rounded-lg shadow p-12 text-center">
        <h2 class="text-2xl font-bold mb-2">No applications yet</h2>
        <p class="text-gray-600 mb-4">You haven't applied for any pets yet.</p>
        <a asp-area="" asp-controller="Adoption" asp-action="Index"
           class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
            Browse Adoptable Pets
        </a>
    </div>
}
else
{
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="text-left px-4 py-3 font-bold text-gray-700">Pet</th>
                    <th class="text-left px-4 py-3 font-bold text-gray-700">Listing</th>
                    <th class="text-left px-4 py-3 font-bold text-gray-700">Applied</th>
                    <th class="text-left px-4 py-3 font-bold text-gray-700">Status</th>
                    <th class="text-right px-4 py-3 font-bold text-gray-700">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var app in Model)
                {
                    var badgeClass = app.Status switch
                    {
                        ApplicationStatus.Submitted => "bg-blue-100 text-blue-800",
                        ApplicationStatus.UnderReview => "bg-yellow-100 text-yellow-800",
                        ApplicationStatus.Approved => "bg-green-100 text-green-800",
                        ApplicationStatus.Rejected => "bg-red-100 text-red-800",
                        ApplicationStatus.Withdrawn => "bg-gray-100 text-gray-800",
                        _ => "bg-gray-100 text-gray-800"
                    };
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-bold">@app.PetName</td>
                        <td class="px-4 py-3 text-gray-600">@app.ListingTitle</td>
                        <td class="px-4 py-3 text-gray-600">@app.CreatedAt.ToString("MMM d, yyyy")</td>
                        <td class="px-4 py-3">
                            <span class="text-xs px-2 py-1 rounded-full @badgeClass">@app.Status</span>
                        </td>
                        <td class="px-4 py-3 text-right space-x-2">
                            <a asp-action="ApplicationDetails" asp-route-id="@app.Id"
                               class="text-blue-600 hover:text-blue-800 text-xs font-bold">View Details</a>
                            @if (app.Status == ApplicationStatus.Submitted)
                            {
                                <form asp-action="Withdraw" asp-route-id="@app.Id" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-red-600 hover:text-red-800 text-xs font-bold"
                                            onclick="return confirm('Are you sure you want to withdraw this application?')">
                                        Withdraw
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
