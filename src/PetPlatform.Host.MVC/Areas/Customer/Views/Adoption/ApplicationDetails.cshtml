@model PetPlatform.Application.DTOs.AdoptionApplicationDto
@using PetPlatform.Domain.Enums
@{
    ViewData["Title"] = "Application Details";
    var badgeClass = Model.Status switch
    {
        ApplicationStatus.Submitted => "bg-blue-100 text-blue-800",
        ApplicationStatus.UnderReview => "bg-yellow-100 text-yellow-800",
        ApplicationStatus.Approved => "bg-green-100 text-green-800",
        ApplicationStatus.Rejected => "bg-red-100 text-red-800",
        ApplicationStatus.Withdrawn => "bg-gray-100 text-gray-800",
        _ => "bg-gray-100 text-gray-800"
    };
}

<div class="max-w-2xl mx-auto">
    <a asp-action="MyApplications" class="text-blue-600 hover:text-blue-800 text-sm mb-4 inline-block">&larr; My Applications</a>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
            @TempData["Error"]
        </div>
    }

    @* Application Info *@
    <div class="bg-white rounded-lg shadow p-6 mb-6">
        <div class="flex items-center gap-3 mb-4">
            <h1 class="text-xl font-bold">Application Details</h1>
            <span class="text-xs px-2 py-1 rounded-full @badgeClass">@Model.Status</span>
        </div>

        <div class="space-y-2 text-sm text-gray-600 mb-4">
            <p>
                <span class="font-bold">Listing:</span>
                <a asp-area="" asp-controller="Adoption" asp-action="Details" asp-route-id="@Model.ListingId"
                   class="text-blue-600 hover:text-blue-800">@Model.ListingTitle</a>
            </p>
            <p><span class="font-bold">Pet:</span> @Model.PetName</p>
            <p><span class="font-bold">Applied:</span> @Model.CreatedAt.ToString("MMM d, yyyy 'at' h:mm tt")</p>
            @if (Model.UpdatedAt.HasValue)
            {
                <p><span class="font-bold">Last Updated:</span> @Model.UpdatedAt.Value.ToString("MMM d, yyyy 'at' h:mm tt")</p>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="mt-4">
                <h2 class="text-sm font-bold text-gray-700 mb-1">Your Message</h2>
                <p class="text-sm text-gray-600 bg-gray-50 rounded-lg p-3 whitespace-pre-line">@Model.Message</p>
            </div>
        }
    </div>

    @* Review Section *@
    @if (Model.ReviewedByUserId != null || !string.IsNullOrEmpty(Model.ReviewNotes))
    {
        <div class="bg-white rounded-lg shadow p-6 mb-6">
            <h2 class="text-sm font-bold text-gray-700 mb-2">Shelter Review</h2>
            <div class="space-y-2 text-sm text-gray-600">
                @if (Model.ReviewedByUserId != null)
                {
                    <p><span class="font-bold">Reviewed by:</span> Shelter</p>
                }
                @if (!string.IsNullOrEmpty(Model.ReviewNotes))
                {
                    <p><span class="font-bold">Notes:</span></p>
                    <p class="bg-gray-50 rounded-lg p-3 whitespace-pre-line">@Model.ReviewNotes</p>
                }
            </div>
        </div>
    }

    @* Status Timeline *@
    @if (Model.StatusHistory.Any())
    {
        <div class="bg-white rounded-lg shadow p-6 mb-6">
            <h2 class="text-sm font-bold text-gray-700 mb-4">Status History</h2>
            <div class="space-y-4">
                @foreach (var entry in Model.StatusHistory.OrderByDescending(s => s.ChangedAt))
                {
                    var dotColor = entry.Status switch
                    {
                        ApplicationStatus.Submitted => "bg-blue-500",
                        ApplicationStatus.UnderReview => "bg-yellow-500",
                        ApplicationStatus.Approved => "bg-green-500",
                        ApplicationStatus.Rejected => "bg-red-500",
                        ApplicationStatus.Withdrawn => "bg-gray-500",
                        _ => "bg-gray-500"
                    };
                    <div class="flex gap-3">
                        <div class="flex flex-col items-center">
                            <div class="w-3 h-3 rounded-full @dotColor mt-1"></div>
                            <div class="w-0.5 flex-1 bg-gray-200"></div>
                        </div>
                        <div class="pb-4">
                            <p class="text-sm font-bold text-gray-700">@entry.Status</p>
                            <p class="text-xs text-gray-500">@entry.ChangedAt.ToString("MMM d, yyyy 'at' h:mm tt")</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* Actions *@
    @if (Model.Status == ApplicationStatus.Submitted)
    {
        <div class="bg-white rounded-lg shadow p-6">
            <form asp-action="Withdraw" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full bg-red-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-red-700 transition-colors"
                        onclick="return confirm('Are you sure you want to withdraw this application? This cannot be undone.')">
                    Withdraw Application
                </button>
            </form>
        </div>
    }
    else if (Model.Status == ApplicationStatus.Withdrawn)
    {
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center text-sm text-gray-600">
            This application has been withdrawn.
        </div>
    }
    else if (Model.Status == ApplicationStatus.Rejected)
    {
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-center text-sm text-red-600">
            This application was not approved. You may apply for other listings.
        </div>
    }
    else if (Model.Status == ApplicationStatus.Approved)
    {
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center text-sm text-green-600">
            Congratulations! Your application has been approved. The shelter will contact you with next steps.
        </div>
    }
</div>
