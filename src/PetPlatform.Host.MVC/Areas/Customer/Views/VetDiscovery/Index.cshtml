@model PetPlatform.Application.DTOs.PagedResultDto<PetPlatform.Application.DTOs.VetProfileDto>
@{
    ViewData["Title"] = "Find a Veterinarian";
}

<div class="max-w-6xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Find a Veterinarian</h1>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
            @TempData["Success"]
        </div>
    }

    <div class="flex gap-6">
        <!-- Search Sidebar -->
        <div class="w-64 flex-shrink-0">
            <form asp-action="Index" method="get" class="bg-white rounded-lg shadow p-4 space-y-4">
                <h3 class="font-semibold text-gray-700">Search & Filter</h3>

                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Search</label>
                    <input type="text" name="search" value="@ViewData["SearchTerm"]"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-sm"
                           placeholder="Name or clinic..." />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Specialty</label>
                    <input type="text" name="specialty" value="@ViewData["Specialty"]"
                           class="w-full border border-gray-300 rounded px-3 py-2 text-sm"
                           placeholder="e.g. Surgery, Dentistry..." />
                </div>

                <div class="flex items-center gap-2">
                    <input type="checkbox" name="isAvailable" value="true" id="isAvailable"
                           @(ViewData["IsAvailable"]?.ToString() == "True" ? "checked" : "")
                           class="rounded border-gray-300" />
                    <label for="isAvailable" class="text-sm text-gray-600">Available Now</label>
                </div>

                <div class="flex gap-2">
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 px-4 rounded">
                        Apply
                    </button>
                    <a asp-action="Index" class="text-gray-500 hover:text-gray-700 text-sm py-2 px-2">
                        Clear
                    </a>
                </div>
            </form>
        </div>

        <!-- Results -->
        <div class="flex-1">
            @if (!Model.Items.Any())
            {
                <div class="bg-white rounded-lg shadow p-8 text-center">
                    <p class="text-gray-500 text-lg">No vets found matching your criteria</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var vet in Model.Items)
                    {
                        <div class="bg-white rounded-lg shadow p-4">
                            <div class="flex items-center justify-between mb-2">
                                <h3 class="font-semibold text-gray-800">@vet.FullName</h3>
                                @if (vet.IsAvailable)
                                {
                                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Available</span>
                                }
                                else
                                {
                                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Unavailable</span>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(vet.Clinic))
                            {
                                <p class="text-sm text-gray-600 mb-1">@vet.Clinic</p>
                            }
                            @if (!string.IsNullOrEmpty(vet.Specialty))
                            {
                                <p class="text-sm text-gray-500 mb-2">Specialty: @vet.Specialty</p>
                            }
                            @if (!string.IsNullOrEmpty(vet.Bio))
                            {
                                <p class="text-sm text-gray-500 mb-3 line-clamp-2">@vet.Bio</p>
                            }

                            <a asp-action="Details" asp-route-id="@vet.Id"
                               class="inline-block bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 px-4 rounded">
                                View Profile
                            </a>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="flex justify-center gap-2 mt-6">
                        @if (Model.HasPreviousPage)
                        {
                            <a asp-action="Index" asp-route-page="@(Model.Page - 1)"
                               asp-route-search="@ViewData["SearchTerm"]"
                               asp-route-specialty="@ViewData["Specialty"]"
                               asp-route-isAvailable="@ViewData["IsAvailable"]"
                               class="px-3 py-2 border border-gray-300 rounded text-sm hover:bg-gray-50">
                                &laquo; Previous
                            </a>
                        }
                        <span class="px-3 py-2 text-sm text-gray-600">
                            Page @Model.Page of @Model.TotalPages
                        </span>
                        @if (Model.HasNextPage)
                        {
                            <a asp-action="Index" asp-route-page="@(Model.Page + 1)"
                               asp-route-search="@ViewData["SearchTerm"]"
                               asp-route-specialty="@ViewData["Specialty"]"
                               asp-route-isAvailable="@ViewData["IsAvailable"]"
                               class="px-3 py-2 border border-gray-300 rounded text-sm hover:bg-gray-50">
                                Next &raquo;
                            </a>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>
