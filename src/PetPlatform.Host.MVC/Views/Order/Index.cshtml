@model IEnumerable<PetPlatform.Application.DTOs.OrderDto>
@{
    ViewData["Title"] = "My Orders";
}

<h1 class="text-2xl font-bold mb-6">My Orders</h1>

@if (!Model.Any())
{
    <div class="bg-white rounded-lg shadow p-12 text-center">
        <h2 class="text-2xl font-bold mb-2">No orders yet</h2>
        <p class="text-gray-600 mb-4">When you place an order, it will appear here.</p>
        <a asp-controller="Catalog" asp-action="Index"
           class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
            Start Shopping
        </a>
    </div>
}
else
{
    <div class="bg-white rounded-lg shadow overflow-hidden">
        @foreach (var order in Model)
        {
            <a asp-action="Details" asp-route-id="@order.Id"
               class="flex items-center justify-between p-4 border-b border-gray-200 hover:bg-gray-50 transition-colors">
                <div class="flex items-center gap-4">
                    <div>
                        <span class="font-bold">Order #@order.Id</span>
                        <p class="text-sm text-gray-500">@order.CreatedAt.ToString("MMM dd, yyyy")</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="inline-block px-3 py-1 rounded-full text-xs font-bold
                        @(order.Status == PetPlatform.Domain.Enums.OrderStatus.Pending ? "bg-yellow-100 text-yellow-800" :
                          order.Status == PetPlatform.Domain.Enums.OrderStatus.Processing ? "bg-blue-100 text-blue-800" :
                          order.Status == PetPlatform.Domain.Enums.OrderStatus.Shipped ? "bg-purple-100 text-purple-800" :
                          "bg-green-100 text-green-800")">
                        @order.StatusText
                    </span>
                    <span class="font-bold" dir="ltr">$@order.TotalAmount.ToString("F2")</span>
                </div>
            </a>
        }
    </div>
}
