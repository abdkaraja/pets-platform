@model PetPlatform.Application.DTOs.OrderDto
@{
    ViewData["Title"] = $"Order #{Model.Id}";
}

@* Breadcrumb *@
<nav class="text-sm text-gray-500 mb-4">
    <a asp-action="Index" class="hover:text-blue-600">Orders</a>
    <span class="mx-1">&rsaquo;</span>
    <span class="text-gray-900">Order #@Model.Id</span>
</nav>

@* Order Header *@
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold">Order #@Model.Id</h1>
        <p class="text-sm text-gray-500">Placed on @Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
    </div>
    <span class="inline-block px-3 py-1 rounded-full text-xs font-bold
        @(Model.Status == PetPlatform.Domain.Enums.OrderStatus.Pending ? "bg-yellow-100 text-yellow-800" :
          Model.Status == PetPlatform.Domain.Enums.OrderStatus.Processing ? "bg-blue-100 text-blue-800" :
          Model.Status == PetPlatform.Domain.Enums.OrderStatus.Shipped ? "bg-purple-100 text-purple-800" :
          "bg-green-100 text-green-800")">
        @Model.StatusText
    </span>
</div>

<div class="flex flex-col lg:flex-row gap-6">
    @* Left: Items & Totals *@
    <div class="flex-1">
        @* Items *@
        <div class="bg-white rounded-lg shadow p-6 mb-6">
            <h2 class="text-lg font-bold mb-4">Items</h2>
            <div class="space-y-4">
                @foreach (var item in Model.Items)
                {
                    <div class="flex items-center gap-4">
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" alt="@item.ProductName" class="w-16 h-16 object-cover rounded shrink-0" />
                        }
                        else
                        {
                            <div class="w-16 h-16 bg-gray-200 rounded shrink-0 flex items-center justify-center">
                                <span class="text-gray-400 text-xs">No Image</span>
                            </div>
                        }
                        <div class="flex-1 min-w-0">
                            <p class="font-bold text-base truncate">@item.ProductName</p>
                            @if (!string.IsNullOrEmpty(item.VariantDescription))
                            {
                                <p class="text-sm text-gray-500">@item.VariantDescription</p>
                            }
                        </div>
                        <div class="text-end shrink-0">
                            <p class="text-sm text-gray-600">@item.Quantity &times; <span dir="ltr">$@item.UnitPrice.ToString("F2")</span></p>
                            <p class="font-bold" dir="ltr">$@item.LineTotal.ToString("F2")</p>
                        </div>
                    </div>
                }
            </div>

            <hr class="border-gray-200 my-4" />

            @* Totals *@
            <div class="space-y-2">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Subtotal</span>
                    <span dir="ltr">$@Model.Items.Sum(i => i.LineTotal).ToString("F2")</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Shipping</span>
                    <span dir="ltr">$5.99</span>
                </div>
                <hr class="border-gray-200 my-2" />
                <div class="flex justify-between font-bold text-lg">
                    <span>Total</span>
                    <span dir="ltr">$@Model.TotalAmount.ToString("F2")</span>
                </div>
            </div>
        </div>
    </div>

    @* Right: Timeline & Shipping *@
    <div class="w-full lg:w-80 shrink-0">
        @* Status Timeline *@
        <div class="bg-white rounded-lg shadow p-6 mb-6">
            <h2 class="text-lg font-bold mb-4">Status Timeline</h2>
            @{
                var allStatuses = new[] {
                    PetPlatform.Domain.Enums.OrderStatus.Pending,
                    PetPlatform.Domain.Enums.OrderStatus.Processing,
                    PetPlatform.Domain.Enums.OrderStatus.Shipped,
                    PetPlatform.Domain.Enums.OrderStatus.Delivered
                };
                var historyLookup = Model.StatusHistory.ToDictionary(h => h.Status);
                var currentStatusIndex = Array.IndexOf(allStatuses, Model.Status);
            }
            <div class="space-y-0">
                @for (var i = 0; i < allStatuses.Length; i++)
                {
                    var status = allStatuses[i];
                    var isCompleted = i <= currentStatusIndex;
                    var isCurrent = i == currentStatusIndex;
                    var hasHistory = historyLookup.TryGetValue(status, out var historyEntry);

                    <div class="flex items-start gap-3 @(i < allStatuses.Length - 1 ? "pb-4" : "")">
                        @* Dot + Line *@
                        <div class="flex flex-col items-center">
                            <div class="w-3 h-3 rounded-full shrink-0 @(isCompleted ? "bg-blue-600" : "bg-gray-300")"></div>
                            @if (i < allStatuses.Length - 1)
                            {
                                <div class="w-0.5 flex-1 @(isCompleted ? "bg-blue-600" : "bg-gray-200")"></div>
                            }
                        </div>
                        @* Content *@
                        <div>
                            <p class="text-sm font-bold @(isCompleted ? "" : "text-gray-400")">@status</p>
                            @if (isCompleted && hasHistory && historyEntry != null)
                            {
                                <p class="text-xs text-gray-500">@historyEntry.ChangedAt.ToString("MMM dd, yyyy HH:mm")</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        @* Shipping *@
        @if (!string.IsNullOrEmpty(Model.ShippingAddress))
        {
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-lg font-bold mb-2">Shipping</h2>
                <p class="text-sm text-gray-600">@Model.ShippingAddress</p>
            </div>
        }
    </div>
</div>
