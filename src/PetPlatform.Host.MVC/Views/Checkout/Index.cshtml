@model PetPlatform.Application.DTOs.CheckoutDto
@{
    ViewData["Title"] = "Checkout";
}

<h1 class="text-2xl font-bold mb-6">Checkout</h1>

<div class="flex flex-col lg:flex-row gap-6">
    @* Left: Form *@
    <div class="flex-1">
        @* Shipping Information *@
        <div class="bg-white rounded-lg shadow p-6 mb-6">
            <h2 class="text-lg font-bold mb-4">Shipping Information</h2>
            <form id="checkout-form" class="space-y-4">
                <div>
                    <label class="text-sm font-bold text-gray-700 mb-1 block">Full Name</label>
                    <input type="text" name="shippingFullName" value="@Model.ShippingFullName"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" required />
                </div>
                <div>
                    <label class="text-sm font-bold text-gray-700 mb-1 block">Address</label>
                    <input type="text" name="shippingAddress" value="@Model.ShippingAddress"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" required />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-sm font-bold text-gray-700 mb-1 block">City</label>
                        <input type="text" name="shippingCity" value="@Model.ShippingCity"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" required />
                    </div>
                    <div>
                        <label class="text-sm font-bold text-gray-700 mb-1 block">Phone</label>
                        <input type="text" name="shippingPhone" value="@Model.ShippingPhone"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" required />
                    </div>
                </div>
            </form>
        </div>

        @* Payment *@
        <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-bold mb-4">Payment</h2>

            <div id="payment-element" class="min-h-[200px] border border-gray-200 rounded-lg p-4 mb-4">
                <div class="text-sm text-gray-400 text-center py-8">Loading payment form...</div>
            </div>

            <button type="button" id="pay-btn"
                    class="w-full bg-blue-600 text-white py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors disabled:bg-gray-300 disabled:cursor-not-allowed"
                    disabled>
                Pay $@Model.TotalAmount.ToString("F2")
            </button>

            <div id="error-display" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 text-red-600 text-sm mt-4">
            </div>
        </div>
    </div>

    @* Right: Order Summary *@
    <div class="w-full lg:w-80 shrink-0">
        <div class="bg-white rounded-lg shadow p-6 lg:sticky lg:top-4">
            <h2 class="text-lg font-bold mb-4">Order Summary</h2>

            <div class="space-y-3 mb-4">
                @foreach (var item in Model.CartItems)
                {
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600 truncate me-2">@item.ProductName x @item.Quantity</span>
                        <span class="shrink-0" dir="ltr">$@item.LineTotal.ToString("F2")</span>
                    </div>
                }
            </div>

            <hr class="border-gray-200 my-4" />

            <div class="space-y-3">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Subtotal</span>
                    <span dir="ltr">$@Model.Subtotal.ToString("F2")</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Shipping</span>
                    <span dir="ltr">$@Model.ShippingCost.ToString("F2")</span>
                </div>
            </div>

            <hr class="border-gray-200 my-4" />

            <div class="flex justify-between text-2xl font-bold">
                <span>Total</span>
                <span dir="ltr">$@Model.TotalAmount.ToString("F2")</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://js.stripe.com/dahlia/stripe.js"></script>
<script>
$(function() {
    var totalAmount = @Model.TotalAmount;
    var returnUrl = window.location.origin + '/Checkout/Confirmation';

    // Create session and initialize Stripe
    $.ajax({
        url: '/Checkout/CreateSession',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({
            ShippingFullName: $('[name="shippingFullName"]').val(),
            ShippingAddress: $('[name="shippingAddress"]').val(),
            ShippingCity: $('[name="shippingCity"]').val(),
            ShippingPhone: $('[name="shippingPhone"]').val(),
            Subtotal: @Model.Subtotal,
            ShippingCost: @Model.ShippingCost
        }),
        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
        success: function(response) {
            if (response.publishableKey && response.clientSecret) {
                initStripe(response.publishableKey, response.clientSecret, response.sessionId);
            }
        },
        error: function(xhr) {
            showError('Failed to initialize payment. Please try again.');
        }
    });

    function initStripe(publishableKey, clientSecret, sessionId) {
        var stripe = Stripe(publishableKey);
        var elements = stripe.elements({ clientSecret: clientSecret, appearance: { theme: 'stripe' } });
        var paymentElement = elements.create('payment');
        paymentElement.mount('#payment-element');

        // Clear loading text
        $('#payment-element .text-gray-400').remove();

        $('#pay-btn').prop('disabled', false);

        $('#pay-btn').click(function() {
            var btn = $(this);
            btn.prop('disabled', true).text('Processing...').addClass('opacity-70');
            $('#error-display').addClass('hidden');

            stripe.confirmPayment({
                elements: elements,
                confirmParams: {
                    return_url: returnUrl + '?session_id=' + sessionId
                }
            }).then(function(result) {
                if (result.error) {
                    showError(result.error.message);
                    btn.prop('disabled', false).text('Pay $' + totalAmount.toFixed(2)).removeClass('opacity-70');
                }
                // On success, redirect happens automatically
            });
        });
    }

    function showError(message) {
        $('#error-display').text(message).removeClass('hidden');
    }
});
</script>
}
