@model PetPlatform.Application.DTOs.PetDto
@{
    ViewData["Title"] = Model.Name;
}

<h1 class="text-2xl font-bold mb-6">@Model.Name</h1>

<div class="bg-white rounded-lg shadow p-6 max-w-lg">
    @if (!string.IsNullOrEmpty(Model.PhotoPath))
    {
        <img src="@Model.PhotoPath" alt="@Model.Name" class="w-full h-64 object-cover rounded mb-4" />
    }

    <div class="space-y-3">
        <div>
            <span class="font-semibold text-gray-600">Species:</span>
            <span class="ml-2">@Model.Species</span>
        </div>
        <div>
            <span class="font-semibold text-gray-600">Breed:</span>
            <span class="ml-2">@(Model.Breed ?? "Not specified")</span>
        </div>
        <div>
            <span class="font-semibold text-gray-600">Age:</span>
            <span class="ml-2">@Model.Age years</span>
        </div>
        <div>
            <span class="font-semibold text-gray-600">Weight:</span>
            <span class="ml-2">@Model.Weight kg</span>
        </div>
    </div>

    <div class="mt-6">
        <a asp-action="Index" class="text-gray-600 hover:text-gray-800">
            &larr; Back to Browse
        </a>
    </div>
</div>
