{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "C:/Projects/pet-platform/.opencode/gsd-core/*": "allow"
    },
    "external_directory": {
      "C:/Projects/pet-platform/.opencode/gsd-core/*": "allow"
    }
  },
  "mcp": {
    "gsd": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "-p",
        "@opengsd/gsd-core",
        "gsd-mcp-server"
      ],
      "enabled": true
    }
  }
}
